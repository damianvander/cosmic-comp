index 00000000..85654944
--- /dev/null
+++ b/src/input/kinetic.rs
@@ -0,0 +1,427 @@
+// SPDX-License-Identifier: GPL-3.0-only
+//
+// Compositor-side kinetic (inertial) scrolling for two-finger touchpad scroll.
+//
+// Buffered finger-source axis deltas feed a closed-form exponential fling on
+// lift; synthetic `wl_pointer.axis` events with `AxisSource::Continuous` are
+// emitted until velocity decays below `STOP_VELOCITY`. When kinetic is active
+// the same `Continuous` source is also used for live finger scroll (see the
+// PointerAxis arm in `mod.rs`), so the fling and the gesture before it look
+// like one uninterrupted stream to the client — no source transitions, no
+// `axis_stop` frames either way, since `Continuous` does not require them.
+
+use crate::state::State;
+use calloop::timer::{TimeoutAction, Timer};
+use smithay::{
+    backend::input::{Axis, AxisSource},
+    input::{Seat, pointer::AxisFrame},
+    utils::{Logical, Point},
+};
+use std::{cell::RefCell, collections::VecDeque, time::Duration};
+
+/// Samples within this window of the most recent push contribute to the
+/// fling velocity at lift; older samples are dropped by [`KineticScroller::trim`].
+/// Biases the velocity estimate toward what the finger was doing *just* before
+/// release rather than averaging across the whole gesture.
+pub const DEFAULT_VELOCITY_WINDOW: Duration = Duration::from_millis(80);
+/// Minimum raw lift velocity (logical units/sec) required to start a fling.
+pub const DEFAULT_MIN_FLING_VELOCITY: f64 = 50.0;
+/// Velocity (logical units/sec) at which exponential decay hands over to the
+/// smooth-stop tail.
+pub const DEFAULT_STOP_VELOCITY: f64 = 15.0;
+/// Per-millisecond friction during the exponential decay phase.
+pub const DEFAULT_FRICTION_PER_MS: f64 = 0.995;
+/// Cap on initial fling velocity so an extreme flick doesn't whip-scroll the
+/// entire page in one frame.
+pub const DEFAULT_MAX_FLING_VELOCITY: f64 = 4000.0;
+/// Duration of the smooth-stop tail (cubic ease-out to zero) that follows
+/// exponential decay. Without it, the fling cuts off abruptly at the stop
+/// velocity which can feel like a snap on low-precision scroll consumers
+/// (terminals, XWayland clients).
+pub const DEFAULT_TAIL_DURATION_MS: f64 = 80.0;
+/// Accumulated relative pointer motion (logical px) during a fling that
+/// cancels it. Small but non-zero: finger-lift can produce sub-pixel jitter
+/// motion events at the exact moment a fling starts, and cancelling on
+/// literally any motion would kill most flings instantly.
+pub const DEFAULT_MOTION_CANCEL_THRESHOLD: f64 = 2.0;
+/// Tick interval for the fling timer (~125 Hz).
+const TICK: Duration = Duration::from_millis(8);
+
+/// Kinetic-scroll tunables with every option resolved to a concrete value.
+/// Produced from `KineticScrollConfig` by `Config::kinetic_scroll_params`;
+/// [`Default`] is the built-in `DEFAULT_*` constants above.
+#[derive(Clone, Copy, Debug)]
+pub struct KineticParams {
+    pub friction_per_ms: f64,
+    pub min_fling_velocity: f64,
+    pub max_fling_velocity: f64,
+    pub stop_velocity: f64,
+    pub tail_duration_ms: f64,
+    pub velocity_window: Duration,
+    pub motion_cancel_threshold: f64,
+}
+
+impl Default for KineticParams {
+    fn default() -> Self {
+        Self {
+            friction_per_ms: DEFAULT_FRICTION_PER_MS,
+            min_fling_velocity: DEFAULT_MIN_FLING_VELOCITY,
+            max_fling_velocity: DEFAULT_MAX_FLING_VELOCITY,
+            stop_velocity: DEFAULT_STOP_VELOCITY,
+            tail_duration_ms: DEFAULT_TAIL_DURATION_MS,
+            velocity_window: DEFAULT_VELOCITY_WINDOW,
+            motion_cancel_threshold: DEFAULT_MOTION_CANCEL_THRESHOLD,
+        }
+    }
+}
+
+#[derive(Clone, Copy, Debug)]
+struct Sample {
+    delta: Point<f64, Logical>,
+    time: Duration,
+}
+
+#[derive(Default)]
+pub struct KineticScroller(RefCell<Inner>);
+
+#[derive(Default)]
+struct Inner {
+    samples: VecDeque<Sample>,
+    velocity: Point<f64, Logical>,
+    active: bool,
+    last_tick: Option<Duration>,
+    /// True once exponential decay has dropped below the stop velocity and
+    /// we've switched to the cubic-ease-out tail.
+    in_tail: bool,
+    tail_start: Option<Duration>,
+    tail_initial_velocity: Point<f64, Logical>,
+    /// Resolved tunables, refreshed from config on every [`KineticScroller::push`];
+    /// a running fling uses whatever was stored at gesture time.
+    params: KineticParams,
+    /// Relative pointer motion (logical px) accumulated while a fling is
+    /// active; once it exceeds `params.motion_cancel_threshold` the fling is
+    /// cancelled.
+    motion_accum: f64,
+}
+
+impl Inner {
+    fn clear_fling(&mut self) {
+        self.active = false;
+        self.velocity = Point::default();
+        self.last_tick = None;
+        self.in_tail = false;
+        self.tail_start = None;
+        self.tail_initial_velocity = Point::default();
+        self.motion_accum = 0.0;
+    }
+}
+
+/// Outcome of a single fling [`KineticScroller::tick`].
+enum Tick {
+    /// Emit this delta and keep ticking.
+    Frame(Point<f64, Logical>),
+    /// The fling decayed to a stop this tick — emit a terminating
+    /// `axis_stop` and stop ticking.
+    Done,
+    /// No fling is running (it was cancelled out from under the timer) —
+    /// do nothing.
+    Idle,
+}
+
+impl KineticScroller {
+    /// Buffer a finger delta and refresh the resolved tunables. If a fling
+    /// was running, cancel it and return `true` so the caller can terminate
+    /// that fling's scroll sequence.
+    fn push(&self, delta: Point<f64, Logical>, t: Duration, params: KineticParams) -> bool {
+        let mut inner = self.0.borrow_mut();
+        inner.params = params;
+        let was_active = inner.active;
+        if inner.active {
+            inner.clear_fling();
+        }
+        inner.samples.push_back(Sample { delta, time: t });
+        Self::trim(&mut inner.samples, t, params.velocity_window);
+        was_active
+    }
+
+    /// Compute velocity from buffered samples and, if above the resolved
+    /// minimum fling velocity, start the fling. Returns the initial velocity
+    /// when a fling actually starts. The buffer is already trimmed to the
+    /// velocity window by [`Self::push`], so `first`/`last` are the velocity
+    /// window directly — no further filtering needed.
+    fn start_fling(&self) -> Option<Point<f64, Logical>> {
+        let mut inner = self.0.borrow_mut();
+        let params = inner.params;
+        let (first, last) = inner.samples.front().zip(inner.samples.back())?;
+        let span = last.time.saturating_sub(first.time).as_secs_f64();
+        let total = inner
+            .samples
+            .iter()
+            .fold(Point::<f64, Logical>::default(), |acc, s| acc + s.delta);
+        inner.samples.clear();
+
+        if span <= 0.0 {
+            return None;
+        }
+        let raw = Point::<f64, Logical>::from((total.x / span, total.y / span));
+        if raw.x.abs() < params.min_fling_velocity && raw.y.abs() < params.min_fling_velocity {
+            return None;
+        }
+
+        let velocity = Point::<f64, Logical>::from((
+            raw.x
+                .clamp(-params.max_fling_velocity, params.max_fling_velocity),
+            raw.y
+                .clamp(-params.max_fling_velocity, params.max_fling_velocity),
+        ));
+        inner.clear_fling();
+        inner.velocity = velocity;
+        inner.active = true;
+        Some(velocity)
+    }
+
+    /// Advance the fling. Returns the delta to emit, or a terminal state once
+    /// the exponential-decay-then-tail sequence completes / is cancelled.
+    fn tick(&self, now: Duration) -> Tick {
+        let mut inner = self.0.borrow_mut();
+        if !inner.active {
+            return Tick::Idle;
+        }
+
+        let params = inner.params;
+        let last = inner.last_tick.unwrap_or(now);
+        let dt_ms = now.saturating_sub(last).as_secs_f64() * 1000.0;
+        inner.last_tick = Some(now);
+
+        if inner.in_tail {
+            let start = inner
+                .tail_start
+                .expect("tail_start set when in_tail is true");
+            let elapsed_ms = now.saturating_sub(start).as_secs_f64() * 1000.0;
+            if elapsed_ms >= params.tail_duration_ms {
+                inner.clear_fling();
+                return Tick::Done;
+            }
+            // Cubic ease-out position curve: velocity(t) = v0 * (1 - t/T)^2.
+            let t_norm = elapsed_ms / params.tail_duration_ms;
+            let v_factor = (1.0 - t_norm).powi(2);
+            let v = inner.tail_initial_velocity;
+            let cur_v = (v.x * v_factor, v.y * v_factor);
+            let dt_s = dt_ms / 1000.0;
+            inner.velocity = Point::from(cur_v);
+            return Tick::Frame(Point::from((cur_v.0 * dt_s, cur_v.1 * dt_s)));
+        }
+
+        let delta = if dt_ms > 0.0 {
+            let factor = params.friction_per_ms.powf(dt_ms);
+            let scale = (factor - 1.0) / params.friction_per_ms.ln() / 1000.0;
+            let v = inner.velocity;
+            let out = Point::from((v.x * scale, v.y * scale));
+            inner.velocity = Point::from((v.x * factor, v.y * factor));
+            out
+        } else {
+            Point::default()
+        };
+
+        if inner.velocity.x.abs() < params.stop_velocity
+            && inner.velocity.y.abs() < params.stop_velocity
+        {
+            // Hand off from exponential decay to the smooth-stop tail.
+            inner.in_tail = true;
+            inner.tail_start = Some(now);
+            inner.tail_initial_velocity = inner.velocity;
+        }
+        Tick::Frame(delta)
+    }
+
+    fn cancel_inner(&self) {
+        let mut inner = self.0.borrow_mut();
+        inner.clear_fling();
+        inner.samples.clear();
+    }
+
+    /// Cancel a running fling (and any buffered samples), reporting whether
+    /// one was actually active so the caller can decide to [`emit_stop`].
+    fn cancel_if_active(&self) -> bool {
+        let mut inner = self.0.borrow_mut();
+        let was_active = inner.active;
+        inner.clear_fling();
+        inner.samples.clear();
+        was_active
+    }
+
+    /// Accumulate relative pointer motion while a fling is active. Returns
+    /// `true` when the accumulated magnitude crosses the resolved
+    /// `motion_cancel_threshold` and the fling was cancelled — the caller
+    /// must then [`emit_stop`] to terminate the scroll sequence.
+    fn accumulate_motion(&self, delta: Point<f64, Logical>) -> bool {
+        let mut inner = self.0.borrow_mut();
+        if !inner.active {
+            // Cheap early-out: this runs on the hot pointer-motion path.
+            return false;
+        }
+        inner.motion_accum += delta.x.hypot(delta.y);
+        if inner.motion_accum > inner.params.motion_cancel_threshold {
+            inner.clear_fling();
+            inner.samples.clear();
+            true
+        } else {
+            false
+        }
+    }
+
+    fn trim(samples: &mut VecDeque<Sample>, latest: Duration, window: Duration) {
+        while let Some(front) = samples.front() {
+            if latest <= front.time + window {
+                break;
+            }
+            samples.pop_front();
+        }
+    }
+}
+
+// ---------------------------------------------------------------------------
+// Plumbing API used by `src/input/mod.rs` and `src/shell/focus/mod.rs`. Kept
+// as free functions so callers don't have to thread `KineticScroller`
+// references manually — they just have a seat.
+
+/// Cancel any running fling and discard buffered samples for this seat. No
+/// `axis_stop` frame is emitted; the kinetic stream uses `AxisSource::Continuous`
+/// which does not require one.
+pub fn cancel(seat: &Seat<State>) {
+    if let Some(scroller) = seat.user_data().get::<KineticScroller>() {
+        scroller.cancel_inner();
+    }
+}
+
+/// Buffer a finger delta and refresh the scroller's resolved tunables.
+/// Cancels any running fling so a renewed gesture starts cleanly. Returns
+/// `true` if a fling was cancelled — the caller should then [`emit_stop`] to
+/// terminate that fling's scroll sequence so clients don't merge it with the
+/// new gesture.
+#[must_use]
+pub fn push(
+    seat: &Seat<State>,
+    delta: Point<f64, Logical>,
+    t: Duration,
+    params: KineticParams,
+) -> bool {
+    seat.user_data()
+        .get::<KineticScroller>()
+        .map(|scroller| scroller.push(delta, t, params))
+        .unwrap_or(false)
+}
+
+/// Feed a relative pointer-motion delta. No-op unless a fling is active; once
+/// the motion accumulated since the fling started exceeds the resolved
+/// `motion_cancel_threshold`, the fling is cancelled and an `axis_stop` frame
+/// is emitted so the client's `Continuous` scroll sequence terminates cleanly
+/// (otherwise clients keep scroll-axis lock).
+pub fn on_pointer_motion(
+    state: &mut State,
+    seat: &Seat<State>,
+    delta: Point<f64, Logical>,
+    time_msec: u32,
+) {
+    let cancelled = seat
+        .user_data()
+        .get::<KineticScroller>()
+        .map(|scroller| scroller.accumulate_motion(delta))
+        .unwrap_or(false);
+    if cancelled {
+        emit_stop(state, seat, time_msec);
+    }
+}
+
+/// Cancel any running fling, emitting a terminating `axis_stop` if one was
+/// actually active. Used by absolute-positioning motion (tablets, VMs) where
+/// there is no meaningful delta to accumulate — any motion cancels.
+pub fn cancel_with_stop(state: &mut State, seat: &Seat<State>, time_msec: u32) {
+    let was_active = seat
+        .user_data()
+        .get::<KineticScroller>()
+        .map(|scroller| scroller.cancel_if_active())
+        .unwrap_or(false);
+    if was_active {
+        emit_stop(state, seat, time_msec);
+    }
+}
+
+/// Emit a `Continuous` `axis_stop` on both axes to delimit the end of a
+/// kinetic scroll sequence. Clients (Chromium/GTK) use this to end the scroll
+/// and reset scroll-axis locking; without it a series of scrolls looks like
+/// one unbroken sequence and stays locked to the first axis.
+pub fn emit_stop(state: &mut State, seat: &Seat<State>, time_msec: u32) {
+    let Some(ptr) = seat.get_pointer() else {
+        return;
+    };
+    let frame = AxisFrame::new(time_msec)
+        .source(AxisSource::Continuous)
+        .stop(Axis::Horizontal)
+        .stop(Axis::Vertical);
+    ptr.axis(state, frame);
+    ptr.frame(state);
+}
+
+/// Try to start a fling from buffered samples. Returns true if one started —
+/// caller should suppress emitting any axis frame for this lift; the fling
+/// will emit decay frames itself.
+pub fn try_start_fling(state: &mut State, seat: &Seat<State>) -> bool {
+    let started = seat
+        .user_data()
+        .get::<KineticScroller>()
+        .and_then(|s| s.start_fling())
+        .is_some();
+    if started {
+        schedule_tick(state, seat);
+    }
+    started
+}
+
+fn schedule_tick(state: &mut State, seat: &Seat<State>) {
+    let seat = seat.clone();
+    let _ = state.common.event_loop_handle.insert_source(
+        Timer::from_duration(TICK),
+        move |_, _, state| {
+            tick_handler(state, &seat);
+            TimeoutAction::Drop
+        },
+    );
+}
+
+fn tick_handler(state: &mut State, seat: &Seat<State>) {
+    let now_time = state.common.clock.now();
+    let time_msec = now_time.as_millis();
+    let now: Duration = now_time.into();
+
+    let result = seat
+        .user_data()
+        .get::<KineticScroller>()
+        .map_or(Tick::Idle, |s| s.tick(now));
+
+    let delta = match result {
+        Tick::Frame(delta) => delta,
+        // Fling decayed to a stop: terminate the Continuous scroll sequence so
+        // the client resets scroll-axis locking. Do not reschedule.
+        Tick::Done => {
+            emit_stop(state, seat, time_msec);
+            return;
+        }
+        // Fling was cancelled out from under the timer (a new gesture, key,
+        // button, focus change, …). Whoever cancelled it terminates the
+        // sequence if needed; just stop ticking.
+        Tick::Idle => return,
+    };
+
+    let mut frame = AxisFrame::new(time_msec).source(AxisSource::Continuous);
+    if delta.x != 0.0 {
+        frame = frame.value(Axis::Horizontal, delta.x);
+    }
+    if delta.y != 0.0 {
+        frame = frame.value(Axis::Vertical, delta.y);
+    }
+    let ptr = seat.get_pointer().unwrap();
+    ptr.axis(state, frame);
+    ptr.frame(state);
+    schedule_tick(state, seat);
+}
