+/// Resolve the app identifier of the surface under the seat's pointer.
+/// Returns `None` for non-window focuses (layer surfaces, lock screen,
+/// popups without a parent toplevel) or when the app_id/WM_CLASS is unset.
+/// Used to look up per-app scroll multipliers.
+fn focused_app_id(seat: &Seat<State>) -> Option<String> {
+    let focus = seat.get_pointer()?.current_focus()?;
+    let app_id = match focus {
+        PointerFocusTarget::WlSurface {
+            toplevel: Some(PointerFocusToplevel::Surface(s)),
+            ..
+        } => s.app_id(),
+        PointerFocusTarget::X11Surface {
+            toplevel: Some(s), ..
+        } => s.app_id(),
+        _ => return None,
+    };
+    (!app_id.is_empty()).then_some(app_id)
