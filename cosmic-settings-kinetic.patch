+/// Build the editable override rows from a config, sorted by app id for a
+/// stable display order.
+fn per_app_scroll_entries(input: &InputConfig) -> Vec<PerAppScrollEntry> {
+    let mut entries: Vec<PerAppScrollEntry> = input
+        .scroll_config
+        .as_ref()
+        .and_then(|s| s.scroll_factor_per_app.as_ref())
+        .map(|map| {
+            map.iter()
+                .map(|(app_id, factor)| PerAppScrollEntry {
+                    app_id: app_id.clone(),
+                    factor: factor.to_string(),
+                })
+                .collect()
+        })
+        .unwrap_or_default();
+    entries.sort_by(|a, b| a.app_id.cmp(&b.app_id));
+    entries
+}
