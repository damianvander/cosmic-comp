+    /// Rebuild `scroll_factor_per_app` from the editable rows and persist it.
+    /// Rows with an empty app id or an unparseable/non-positive factor are
+    /// dropped from the written map but kept in the UI so editing continues.
+    fn commit_per_app_scroll(&mut self) {
+        let map: HashMap<String, f64> = self
+            .per_app_scroll
+            .iter()
+            .filter_map(|entry| {
+                let app_id = entry.app_id.trim();
+                let factor: f64 = entry.factor.trim().parse().ok()?;
+                if app_id.is_empty() || !factor.is_finite() || factor <= 0.0 {
+                    return None;
+                }
+                Some((app_id.to_owned(), factor))
+            })
+            .collect();
+
+        let value = (!map.is_empty()).then_some(map);
+        self.update_input(true, |x| {
+            x.scroll_config
+                .get_or_insert(ScrollConfig::default())
+                .scroll_factor_per_app = value.clone();
+        });
+    }
