+/// Built-in kinetic scrolling defaults, shown whenever the config holds no
+/// explicit value. Keep in sync with `KineticScrollConfig` in cosmic-comp.
+const KINETIC_DEFAULT_FRICTION_PER_MS: f64 = 0.995;
+const KINETIC_DEFAULT_MIN_FLING_VELOCITY: f64 = 50.0;
+const KINETIC_DEFAULT_MAX_FLING_VELOCITY: f64 = 4000.0;
+const KINETIC_DEFAULT_STOP_VELOCITY: f64 = 15.0;
+const KINETIC_DEFAULT_TAIL_DURATION_MS: f64 = 80.0;
+const KINETIC_DEFAULT_VELOCITY_WINDOW_MS: u64 = 80;
+const KINETIC_DEFAULT_MOTION_CANCEL_THRESHOLD: f64 = 2.0;
+
+/// A slider with its current value displayed alongside it, in the style of
+/// the scrolling-speed control.
+fn kinetic_slider<'a>(
+    display: String,
+    value: f64,
+    range: std::ops::RangeInclusive<f64>,
+    step: f64,
+    on_change: impl Fn(f64) -> Message + 'a,
+) -> Element<'a, Message> {
+    let slider = widget::slider(range, value, on_change)
+        .step(step)
+        .width(Length::Fill)
+        .apply(widget::container)
+        .max_width(250);
+
+    row::with_capacity(2)
+        .align_y(Alignment::Center)
+        .spacing(8)
+        .push(
+            text::body(display)
+                .width(Length::Fixed(48.0))
+                .align_x(Alignment::Center),
+        )
+        .push(slider)
+        .into()
+}
