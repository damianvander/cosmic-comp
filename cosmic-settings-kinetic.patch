+fn per_app_scroll() -> Section<crate::pages::Message> {
+    crate::slab!(descriptions {
+        title = fl!("per-app-scroll");
+        desc = fl!("per-app-scroll", "desc");
+        app_id = fl!("per-app-scroll", "app-id");
+        factor = fl!("per-app-scroll", "factor");
+        add = fl!("per-app-scroll", "add");
+    });
+
+    Section::default()
+        .title(fl!("per-app-scroll"))
+        .descriptions(descriptions)
+        .view::<Page>(move |binder, _page, section| {
+            let descriptions = &section.descriptions;
+            let page = binder
+                .page::<super::Page>()
+                .expect("input devices page not found");
+
+            let mut list = settings::section()
+                .title(&section.title)
+                .add(text::body(&descriptions[desc]));
+
+            for (index, entry) in page.per_app_scroll.iter().enumerate() {
+                list = list.add(settings::item_row(vec![
+                    widget::text_input::text_input(
+                        descriptions[app_id].as_str(),
+                        entry.app_id.as_str(),
+                    )
+                    .on_input(move |value| Message::PerAppScrollAppId(index, value))
+                    .width(Length::Fill)
+                    .into(),
+                    widget::text_input::text_input(
+                        descriptions[factor].as_str(),
+                        entry.factor.as_str(),
+                    )
+                    .on_input(move |value| Message::PerAppScrollFactor(index, value))
+                    .width(Length::Fixed(96.0))
+                    .into(),
+                    widget::button::icon(widget::icon::from_name("edit-delete-symbolic"))
+                        .on_press(Message::PerAppScrollRemove(index))
+                        .into(),
+                ]));
+            }
+
+            list.add(
+                widget::button::standard(&descriptions[add])
+                    .leading_icon(widget::icon::from_name("list-add-symbolic"))
+                    .on_press(Message::PerAppScrollAdd),
+            )
+            .apply(Element::from)
+            .map(crate::pages::Message::Input)
+        })
+}
